db.runCommand({
    collMod: "users",
    validator: {
        $jsonSchema: {
            bsonType: "object",
            title: "User Object Validation",
            required: [
                "username",
                "password",
                "passwordplain"
            ],
            properties: {
                username: {
                    bsonType: "string",
                    description: "Name must be a string and it's required",
                },
                passwordPlain: {
                    bsonType: "string",
                    description: "You need the plain password for the testing purposes"
                },
                password: {
                    bsonType: "string", 
                    description: "Password must be a string and it's required too!",
                },
            },
        },
    },
    collMod: "sessions",
    validator: {
        $jsonSchema: {
            bsonType: "object",
            title: "Session object Validation",
            required: [
                "username",
                "expiresAt",
            ],
            properties: {
                username: {
                    bsonType: "string",
                    description: "Username must be a string and it's required",
                },
                expiresAt: {
                    bsonType: "date",
                    description: "Expires at has to be a bson Date, and it's required",
                }
            }
        }
    }
})